# SpacetimeDB
VITE_SPACETIMEDB_DB_NAME=grezwandererdata
VITE_SPACETIMEDB_HOST=ws://localhost:3000

# Frontend
VITE_MAPBOX_TOKEN=your_mapbox_token_here
VITE_MAPBOX_STYLE=mapbox://styles/inoti/cmktqmmks002s01pa3f3gfpll
VITE_ENABLE_AI=false
VITE_ENABLE_DEBUG_CONTENT_SEED=false

# AI worker
# Uses the same operator token/bootstrap flow as the smoke scripts.
GEMINI_API_KEY=your_gemini_api_key_here
AI_WORKER_GEMINI_MODEL=gemini-2.5-flash
AI_WORKER_POLL_MS=2000
AI_WORKER_LEASE_MS=30000
AI_WORKER_MAX_RETRIES=3
AI_WORKER_RETRY_BASE_MS=5000
AI_WORKER_RETRY_MAX_MS=60000

# OpenViking
# For the Gemini OpenAI-compatible OpenViking route, use a Gemini API key.
# start-mcp.ps1 checks OPENVIKING_GOOGLE_API_KEY, then GOOGLE_API_KEY, then GEMINI_API_KEY.
# OPENVIKING_GOOGLE_CREDENTIALS is ignored for this route.
OPENVIKING_GOOGLE_API_KEY=your_gemini_api_key_here
