{
  "name": "Grezwanderer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "dev:all:keepdb": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1 -PreserveDb",
    "prepare": "husky",
    "build": "tsc -b && vite build",
    "format": "prettier . --write --ignore-path .prettierignore",
    "format:check": "prettier . --check --ignore-path .prettierignore",
    "lint": "bun run check:module-bindings-imports && eslint .",
    "check:module-bindings-imports": "bun run scripts/check-module-bindings-imports.ts",
    "quality:release": "bun run lint && bun run test && bun run build",
    "preview": "vite preview",
    "test": "vitest run",
    "content:extract": "bun run scripts/extract-vn-content.ts",
    "smoke:phase1": "bun run scripts/smoke-phase1.ts",
    "smoke:vn-authority": "bun run scripts/smoke-vn-authority.ts",
    "smoke:origin-entry": "bun run scripts/smoke-origin-entry.ts",
    "smoke:origin-handoff": "bun run scripts/smoke-origin-handoff.ts",
    "smoke:mvp-routes": "bun run scripts/smoke-mvp-routes.ts",
    "smoke:mindpalace": "bun run scripts/smoke-mindpalace.ts",
    "smoke:map-authority": "bun run scripts/smoke-map-authority.ts",
    "smoke:all": "bun run scripts/smoke-all.ts",
    "generate": "cargo run -p gen-bindings -- --out-dir src/module_bindings --module-path spacetimedb && bun run scripts/postgenerate.ts && prettier --write src/module_bindings",
    "spacetime:generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path spacetimedb && bun run scripts/postgenerate.ts",
    "spacetime:publish:local": "spacetime publish grezwandererdata --module-path spacetimedb --server local",
    "spacetime:publish:local:clear": "spacetime publish grezwandererdata --clear-database -y --module-path spacetimedb --server local",
    "spacetime:publish": "spacetime publish grezwandererdata --module-path spacetimedb --server maincloud",
    "content:release": "bun run scripts/content-release.ts",
    "content:rollback": "bun run scripts/content-rollback.ts",
    "content:manifest:check": "bun run scripts/content-manifest-check.ts",
    "content:obsidian:coverage:check": "bun run scripts/content-obsidian-coverage-check.ts",
    "content:map:metrics:check": "bun run scripts/content-map-metrics-check.ts",
    "content:map:metrics:update": "bun run scripts/content-map-metrics-update.ts",
    "content:drift:check": "bun run content:extract && bun run content:obsidian:coverage:check && bun run content:map:metrics:check && bun run scripts/content-drift-check.ts"
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^8.1.0",
    "spacetimedb": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/mapbox__point-geometry": "^0.1.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.2.2",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.2.1",
    "husky": "^9.1.7",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.1.5",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings=0"
    ],
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
